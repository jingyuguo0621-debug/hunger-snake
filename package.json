{
  "name": "snake-game",
  "version": "1.0.0",
  "description": "贪吃蛇小游戏",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:dir": "electron-builder --mac --dir",
    "prepare:web": "node -e \"const fs=require('fs');const p='deploy-web';fs.mkdirSync(p,{recursive:true});['index.html','style.css','script.js'].forEach(f=>fs.copyFileSync(f,p+'/'+f));console.log('Done. Drag the folder deploy-web to Netlify Drop.');\""
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.snakegame.app",
    "productName": "Hunger Snake",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "script.js"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
